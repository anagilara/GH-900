@model ghRepo.Models.Product

@{
    ViewData["Title"] = "Eliminar Producto";
}

<h1 class="h3 mb-3 text-danger">Eliminar Producto</h1>
<p>Confirma si deseas eliminar este producto.</p>

<dl class="row">
    <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Name)</dt>
    <dd class="col-sm-10">@Model.Name</dd>

    <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Description)</dt>
    <dd class="col-sm-10">@(string.IsNullOrWhiteSpace(Model.Description) ? "-" : Model.Description)</dd>

    <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Price)</dt>
    <dd class="col-sm-10">@Model.Price.ToString("C")</dd>

    <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Stock)</dt>
    <dd class="col-sm-10">@Model.Stock</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-danger">Eliminar</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
    </div>
</form>